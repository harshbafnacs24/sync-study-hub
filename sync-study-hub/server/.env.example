# ─── Required ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/sync_and_study
JWT_SECRET=replace-with-at-least-32-random-characters

# ─── Optional (defaults shown) ───────────────────────────────────────────────
PORT=4000
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# ─── Third-party (leave blank if not using) ──────────────────────────────────
GOOGLE_CLIENT_ID=
GEMINI_API_KEY=
