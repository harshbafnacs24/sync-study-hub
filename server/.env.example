# Sync & Study backend env vars
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/sync_and_study
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins.
# In dev: the Vite preview origin.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,capacitor://localhost,http://localhost,https://sync-study-hub.harshbafna-cs24.workers.dev,https://sync-study-hub.vercel.app

# Google OAuth Web Client ID (same value used in the React app via
# VITE_GOOGLE_CLIENT_ID). Required only if you enable Google sign-in.
GOOGLE_CLIENT_ID=

# Sage AI — Groq provider (llama-3.3-70b-versatile). If unset, Sage falls back to a mock provider.
# Get a free key at https://console.groq.com
GROQ_API_KEY=
